# ==== Application ====
PROJECT_NAME=Business CRM
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ==== Security ====
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=change-me-super-secret-key-please-override-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ==== PostgreSQL ====
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=crm
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ==== Redis (опционально) ====
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379

# ==== Seed (демо-данные) ====
SEED_ON_STARTUP=true
FIRST_ADMIN_EMAIL=admin@crm.example.com
FIRST_ADMIN_PASSWORD=admin12345
